{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "JUDGE0_API_URL",
    "JUDGE0_API_KEY",
    "JUDGE0_DAILY_LIMIT",
    "JUDGE0_REQUEST_TIMEOUT_MS",
    "GROQ_API_KEY",
    "GROQ_MODEL",
    "GROQ_API_URL",
    "GROQ_MAX_TOKENS",
    "GROQ_TEMPERATURE",
    "GROQ_REQUEST_TIMEOUT_MS",
    "LEETCODE_GRAPHQL_URL",
    "LEETCODE_REQUEST_TIMEOUT_MS",
    "PORT",
    "NODE_ENV",
    "CORS_ORIGIN",
    "ALLOWED_ORIGINS",
    "LOG_LEVEL",
    "RATE_LIMIT_ROOM_CREATE",
    "RATE_LIMIT_WS_CONNECT",
    "RATE_LIMIT_JOIN",
    "RATE_LIMIT_IMPORT",
    "TRUSTED_PROXY_IPS",
    "ENABLE_PROBLEM_IMPORT",
    "ENABLE_LLM_HINT_FALLBACK",
    "ENABLE_IMPORTED_PROBLEM_HINTS",
    "MAX_SOCKET_EVENT_BYTES",
    "MAX_CODE_BYTES",
    "MAX_YJS_MESSAGE_BYTES",
    "MAX_YJS_DOC_BYTES",
    "MAX_LLM_CALLS_PER_ROOM",
    "MAX_LLM_PROMPT_CHARS",
    "MAX_LLM_HINT_CHARS",
    "ROOM_GRACE_PERIOD_MS",
    "ROOM_HINT_CONSENT_MS",
    "ROOM_MAX_SUBMISSIONS",
    "ROOM_MAX_IMPORTS",
    "ROOM_MAX_CUSTOM_TEST_CASES",
    "IMPORTS_DAILY_LIMIT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "outputs": []
    }
  }
}
