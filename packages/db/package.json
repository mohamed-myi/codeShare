{
  "name": "@codeshare/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src",
    "lint": "biome check src/",
    "migrate": "tsx src/migrations/migrate.ts",
    "seed": "tsx src/seeds/seed.ts",
    "soft-delete": "tsx src/scripts/softDeleteProblem.ts",
    "clean-e2e-imports": "tsx src/scripts/cleanE2eImports.ts",
    "clean-python-future-imports": "tsx src/scripts/cleanPythonFutureImports.ts"
  },
  "dependencies": {
    "@codeshare/shared": "workspace:*",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
