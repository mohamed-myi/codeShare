{
  "name": "@codeshare/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "tsx src/migrations/migrate.ts",
    "seed": "tsx src/seeds/seed.ts"
  },
  "dependencies": {
    "@codeshare/shared": "workspace:*",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.0"
  }
}
